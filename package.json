{
  "name": "Emitkit",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@orpc/client": "^1.13.14",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @Emitkit/db db:push",
    "db:studio": "turbo -F @Emitkit/db db:studio",
    "db:generate": "turbo -F @Emitkit/db db:generate",
    "db:migrate": "turbo -F @Emitkit/db db:migrate",
    "db:local": "turbo -F @Emitkit/db db:local",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "bun test e2e"
  },
  "dependencies": {
    "@Emitkit/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@Emitkit/config": "workspace:*",
    "@types/bun": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.3.14"
}
